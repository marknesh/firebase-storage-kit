{
  "$schema": "https://turbo.build/schema.json",

  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },

    "dev": {
      "cache": false,
      "persistent": true
    },

    "clean": {
      "cache": false
    },

    "typecheck": {
      "dependsOn": ["^typecheck"]
    },

    "test": {
      "cache": false
    },

    "//#check": {},
    "//#fix": {
      "cache": false
    }
  }
}
