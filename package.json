{
  "name": "firebase-storage-kit-workspace",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "clean": "turbo run clean",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "turbo run build && changeset publish",
    "check": "ultracite check --type-aware",
    "fix": "ultracite fix --type-aware",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.31.0",
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.5",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "oxlint-tsgolint": "^0.23.0",
    "tsup": "^8.5.1",
    "turbo": "^2.9.14",
    "ultracite": "7.8.0"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css}": "ultracite fix --type-aware"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "packageManager": "bun@1.3.13"
}
