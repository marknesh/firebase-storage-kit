{
  "name": "firebase-storage-kit",
  "version": "0.0.3",
  "description": "Upload manager for Firebase Storage with progress, cancellation, batch uploads, and configurable concurrency.",
  "keywords": [
    "firebase",
    "firebase-storage",
    "upload",
    "resumable",
    "browser",
    "typescript"
  ],
  "license": "MIT",
  "author": "marknesh (https://github.com/marknesh)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marknesh/firebase-storage-kit.git",
    "directory": "packages/firebase-storage-kit"
  },
  "bugs": {
    "url": "https://github.com/marknesh/firebase-storage-kit/issues"
  },
  "homepage": "https://github.com/marknesh/firebase-storage-kit#readme",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./firebase": {
      "types": "./dist/firebase.d.ts",
      "import": "./dist/firebase.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "firebase": "^12.13.0"
  },
  "peerDependenciesMeta": {
    "firebase": {
      "optional": true
    }
  },
  "devDependencies": {
    "firebase": "^12.13.0"
  }
}
